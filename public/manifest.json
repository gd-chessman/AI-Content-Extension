{
  "manifest_version": 3,
  "name": "AI Content Extension - LE VAN QUY",
  "description": "Chrome extension UI for Facebook, ChatGPT, Grok, Admin, and Excel workflows.",
  "version": "0.1.0",
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "AI Content Extension - LE VAN QUY",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "permissions": ["storage", "activeTab", "scripting", "tabs", "sidePanel", "downloads"],
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://chatgpt.com/*",
    "https://grok.com/*",
    "https://*.google.com/*",
    "https://*/*"
  ]
}
